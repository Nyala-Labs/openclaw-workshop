# --- LLM (required for model-backed runs) ---
#
# OpenAI-style (example):
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#
# Mistral (example — confirm URLs in current Mistral docs):
#   LLM_API_KEY=...
#   LLM_BASE_URL=https://api.mistral.ai/v1
#   LLM_MODEL=mistral-small-latest
#
LLM_API_KEY=your_provider_api_key_here
LLM_BASE_URL=
LLM_MODEL=

OPENCLAW_GATEWAY_TOKEN=

# --- Security: require human approval before shell/exec or destructive ops ---
REQUIRE_EXEC_APPROVAL=true
