# --- LLM (required for agent reasoning) ---
LLM_API_KEY=your_provider_api_key_here

# --- Telegram (optional; enable for remote control / notifications) ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_numeric_chat_id

# --- Security: require human approval before shell/exec or destructive ops ---
# Set to true in workshops and production unless you fully trust the environment.
REQUIRE_EXEC_APPROVAL=true
